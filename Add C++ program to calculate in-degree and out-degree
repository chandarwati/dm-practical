
#include <iostream>
#include <vector>
using namespace std;
 
class Graph {
    int n;
    vector<vector<int>> matrix;
 
public:
    Graph(int vertices) {
        n = vertices;
        matrix.resize(n, vector<int>(n, 0));
    }
 
    void input() {
        cout << "Enter adjacency matrix (" << n << "x" << n << "):\n";
        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++)
                cin >> matrix[i][j];
    }
 
    void display() {
        cout << "\nAdjacency Matrix:\n";
        cout << "    ";
        for (int i = 0; i < n; i++)
            cout << "v" << i+1 << " ";
        cout << "\n";
        for (int i = 0; i < n; i++) {
            cout << "v" << i+1 << "  ";
            for (int j = 0; j < n; j++)
                cout << " " << matrix[i][j] << " ";
            cout << "\n";
        }
        cout << "\n";
    }
 
    int outDegree(int i) {
        int count = 0;
        for (int j = 0; j < n; j++)
            if (matrix[i][j] == 1)
                count++;
        return count;
    }
 
    int inDegree(int j) {
        int count = 0;
        for (int i = 0; i < n; i++)
            if (matrix[i][j] == 1)
                count++;
        return count;
    }
 
    void computeDegrees() {
        int totalIn = 0, totalOut = 0;
 
        cout << "Vertex  |  In-degree  |  Out-degree\n";
        cout << "-------------------------------------\n";
        for (int i = 0; i < n; i++) {
            int in = inDegree(i);
            int out = outDegree(i);
            totalIn += in;
            totalOut += out;
            cout << "  v" << i+1 << "    |      " << in << "      |      " << out << "\n";
        }
        cout << "-------------------------------------\n";
        cout << " Total  |      " << totalIn << "      |      " << totalOut << "\n";
    }
};
 
int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;
 
    Graph g(n);
    g.input();
    g.display();
    g.computeDegrees();
 
    return 0;
}
