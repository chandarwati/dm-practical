
#include <iostream>
#include <vector>
#include <cmath>
using namespace std;
 
class Polynomial {
    vector<double> coeffs;
    int degree;
 
public:
    Polynomial(int deg) {
        degree = deg;
        coeffs.resize(deg + 1);
        cout << "Enter coefficients from highest degree to lowest:\n";
        for (int i = deg; i >= 0; i--) {
            cout << "Coefficient of x^" << i << ": ";
            cin >> coeffs[i];
        }
    }
 
    double evaluate(double x) {
        double result = 0;
        for (int i = degree; i >= 0; i--)
            result += coeffs[i] * pow(x, i);
        return result;
    }
 
    void display() {
        cout << "f(x) = ";
        bool first = true;
        for (int i = degree; i >= 0; i--) {
            if (coeffs[i] == 0) continue;
            if (!first && coeffs[i] > 0) cout << " + ";
            else if (coeffs[i] < 0) cout << " - ";
            if (i == 0)
                cout << abs(coeffs[i]);
            else if (abs(coeffs[i]) != 1)
                cout << abs(coeffs[i]);
            if (i == 1) cout << "x";
            else if (i > 1) cout << "x^" << i;
            first = false;
        }
        cout << "\n";
    }
};
 
int main() {
    int deg;
    cout << "Enter degree of polynomial: ";
    cin >> deg;
 
    Polynomial p(deg);
 
    cout << "\n";
    p.display();
 
    char ch;
    do {
        double x;
        cout << "\nEnter value of x: ";
        cin >> x;
        cout << "f(" << x << ") = " << p.evaluate(x) << "\n";
        cout << "Evaluate for another value? (y/n): ";
        cin >> ch;
    } while (ch == 'y' || ch == 'Y');
 
    return 0;
}
