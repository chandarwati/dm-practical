

#include <iostream>
#include <vector>
using namespace std;
 
int n, C;
int count = 0;
 
void solve(vector<int>& x, int index, int remaining) {
    if (index == n - 1) {
        x[index] = remaining;
        for (int i = 0; i < n; i++) {
            cout << "x" << i+1 << " = " << x[i];
            if (i != n - 1) cout << ",  ";
        }
        cout << "\n";
        count++;
        return;
    }
    for (int val = 0; val <= remaining; val++) {
        x[index] = val;
        solve(x, index + 1, remaining - val);
    }
}
 
int main() {
    cout << "Enter value of n (number of variables): ";
    cin >> n;
    cout << "Enter value of C (constant, C <= 10): ";
    cin >> C;
 
    cout << "\nSolutions of x1";
    for (int i = 2; i <= n; i++) cout << " + x" << i;
    cout << " = " << C << "  (nonnegative integers):\n";
    cout << string(45, '-') << "\n";
 
    vector<int> x(n, 0);
    solve(x, 0, C);
 
    cout << string(45, '-') << "\n";
    cout << "Total solutions: " << count << "\n";
    return 0;
}
